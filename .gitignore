node_modules/
.DS_Store
*.log
.pear/
pear-storage/
test-storage/
*-corestore/
coverage/
.env
.env.*
artifacts/
!artifacts/.gitkeep
dist/
# /build is TRACKED (Electron-Forge maker inputs: entitlements, AppxManifest,
# icons, metainfo, snapcraft — hello-pear-electron conventions); platform build
# scratch dirs elsewhere stay ignored via the patterns below.
mobile/**/build/
*.tsbuildinfo
.idea/
.vscode/
.planning/
website/

# Icon build intermediates (regenerable via scripts/build-icons.sh).
# The placed/wired final assets — assets/, mobile/pearpaste-expo/assets/images/ —
# ARE committed; only the staging directory under ui/shared/assets/icon-out/ is not.
ui/shared/assets/icon-out/

# Mobile / React Native build artifacts (regenerable).
# Ruby bundle (CocoaPods toolchain) — never commit; regenerate with `bundle install`.
mobile/PearPasteMobile/vendor/
# CocoaPods install output.
mobile/PearPasteMobile/ios/Pods/
mobile/PearPasteMobile/ios/build/
# Android gradle outputs.
mobile/PearPasteMobile/android/build/
mobile/PearPasteMobile/android/app/build/
mobile/PearPasteMobile/android/.gradle/
# Expo / Metro caches.
mobile/pearpaste-expo/.expo/
mobile/pearpaste-expo/web-build/
# Legacy all-host Bare-pack output. The shipped platform bundles are committed
# and guarded by `npm --prefix mobile/pearpaste-expo run bundle:bare:check`.
mobile/backend/app.bundle.js

# release flow artifacts (local mirror + notes regenerated each release)
.pear-stage/
RELEASE_NOTES_*.txt

# Windows launcher build outputs (regenerated by dotnet publish).
scripts/windows-launcher/bin/
scripts/windows-launcher/obj/

# Internal launch/marketing drafts — keep out of the public tree.
docs/launch/
out/
