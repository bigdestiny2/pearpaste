# Icon build intermediates (regenerable via scripts/build-icons.sh).
# The placed/wired final assets — assets/, mobile/pearpaste-expo/assets/images/ —
# ARE committed; only the staging directory under ui/shared/assets/icon-out/ is not.
ui/shared/assets/icon-out/

# Mobile / React Native build artifacts (regenerable).
# Ruby bundle (CocoaPods toolchain) — never commit; regenerate with `bundle install`.
mobile/PearPasteMobile/vendor/
# CocoaPods install output.
mobile/PearPasteMobile/ios/Pods/
mobile/PearPasteMobile/ios/build/
# Android gradle outputs.
mobile/PearPasteMobile/android/build/
mobile/PearPasteMobile/android/app/build/
mobile/PearPasteMobile/android/.gradle/
# Expo / Metro caches.
mobile/pearpaste-expo/.expo/
mobile/pearpaste-expo/web-build/
# Bare-pack bundle outputs (regenerated by mobile/bare-pack.config).
mobile/backend/app.bundle.js
mobile/backend/app.android.bundle.js
mobile/backend/app.ios.bundle.js
