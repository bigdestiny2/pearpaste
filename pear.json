{
  "name": "pearpaste",
  "type": "desktop",
  "description": "Personal, end-to-end encrypted note and clipboard sync over Pear / Holepunch.",
  "main": "index.js",
  "pre": "pear-electron/pre",
  "gui": {
    "backgroundColor": "#07090c",
    "height": 720,
    "width": 1040,
    "minHeight": 560,
    "minWidth": 820,
    "icon": {
      "darwin": "assets/Paste.icns",
      "win32": "assets/Paste.ico",
      "linux": "assets/icon-512.png",
      "default": "assets/icon.png"
    }
  },
  "previewFor": "pearpaste",
  "stage": {
    "entrypoints": [
      "index.js",
      "index.html",
      "backend/desktop-worker.mjs"
    ],
    "ignore": [
      "/.git",
      "/test",
      "/docs",
      "/node_modules/.cache"
    ]
  }
}
